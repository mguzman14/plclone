version: '3.9'

services:
  weavescope:
    image: weaveworks/scope:{{ scope_version | default('latest') }}
    container_name: weavescope
    network_mode: host
    pid: host
    privileged: true
    restart: always
    volumes:
      - "/run/user/1000/podman/podman.sock:/var/run/docker.sock:Z"
    command: 
      - "--probe.docker=true"
      - "--probe.kubernetes=false"
      - "--weave=false"
      - "--app.bind=:8081"

networks:
  network_all:
    external: true