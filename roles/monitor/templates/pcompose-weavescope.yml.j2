version: '3.9'

services:
  weavescope:
    image: weaveworks/scope:{{ scope_version | default('latest') }}
    container_name: weavescope
    network_mode: host
    pid: host
    privileged: true
    restart: always
    volumes:
      - "/run/podman/podman.sock:/var/run/docker.sock"
    command:
      - "--probe.docker=true"
      - "--weave=false"
      # Importante: Weave Scope suele escuchar en el 4040 por defecto
    labels:
      - "traefik.enable=true"
    command:
      - "--probe.docker=true"
      - "--app.bind=:8081"
      
networks:
  network_all:
    external: true